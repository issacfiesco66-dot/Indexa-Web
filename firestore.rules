rules_version = '2';
// Force re-deploy v2
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: verifica si el usuario tiene rol 'admin' en /usuarios/{uid} ──
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == "admin";
    }

    function isOwner(ownerId) {
      return request.auth != null && request.auth.uid == ownerId;
    }

    // ── leads (formulario público) ──────────────────────────────────────────
    // Crear: público, pero validate required fields + size limits to prevent spam
    // Leer, actualizar, eliminar: solo admin
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(["contactName", "businessName", "phone", "email", "status"])
        && request.resource.data.contactName is string
        && request.resource.data.contactName.size() > 0
        && request.resource.data.contactName.size() < 200
        && request.resource.data.businessName is string
        && request.resource.data.businessName.size() > 0
        && request.resource.data.businessName.size() < 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 7
        && request.resource.data.phone.size() < 20
        && request.resource.data.email is string
        && request.resource.data.email.size() > 5
        && request.resource.data.status == "nuevo";
      allow read, update, delete: if isAdmin();
    }

    // ── prospectos_frios (CRM / Scraper) ────────────────────────────────────
    // TODAS las operaciones: solo admin
    match /prospectos_frios/{docId} {
      allow read, write: if isAdmin();
    }

    // ── usuarios (perfiles) ─────────────────────────────────────────────────
    // Leer: el propio usuario o admin
    // Escribir: admin tiene acceso total; owner solo puede actualizar campos de integración
    match /usuarios/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == "cliente");
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(["role", "sitioId", "email", "displayName"])
        );
    }

    // ── sitios (páginas públicas de clientes) ───────────────────────────────
    // Leer: público (las webs deben ser visibles para todos)
    // Crear: admin o usuario autenticado (auto-create al comprar plan)
    // Actualizar: admin full access; owner safe fields; webhook payment fields
    // Eliminar: solo admin
    match /sitios/{sitioId} {
      allow read: if true;
      allow create: if isAdmin()
        || (request.auth != null && request.resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (
          request.auth != null
          && resource.data.ownerId == request.auth.uid
          && (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(["ownerId", "statusPago", "plan", "stripeCustomerId", "stripeSubscriptionId", "fechaVencimiento", "ultimoPagoAt"]))
        )
        // Webhook updates (Stripe signature verified server-side):
        // Allow unauthenticated updates ONLY to payment fields
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["statusPago", "plan", "stripeCustomerId", "stripeSubscriptionId", "fechaVencimiento", "ultimoPagoAt"])
        )
        // Bio visit tracking (public API route, no auth needed)
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["bioStats"])
        );
    }

    // ── configuracion (admin settings) ──────────────────────────────────────
    match /configuracion/{docId} {
      allow read, write: if isAdmin();
    }

    // ── webhook_events (audit trail — webhook writes, admin reads) ─────────
    match /webhook_events/{eventId} {
      allow read: if isAdmin();
      allow create, update: if true; // Webhook server verifies Stripe signature
    }

    // ── Cualquier otra colección: denegado por defecto ──────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
